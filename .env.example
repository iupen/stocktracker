# --- StockTracker env vars (optional; .streamlit/secrets.toml is preferred) ---
# Only needed if you run WITHOUT a secrets.toml (e.g. exporting vars in a shell
# or another host). Streamlit Community Cloud uses the dashboard Secrets instead.
# NEVER commit a real .env.

DB_USER=APP_USER
DB_PASSWORD=your-schema-password

# Full one-way TLS connect string from tnsnames.ora (the _high alias). One line.
DB_DSN=(description=(retry_count=20)(retry_delay=3)(address=(protocol=tcps)(port=1521)(host=adb.us-ashburn-1.oraclecloud.com))(connect_data=(service_name=abcd1234_mydb_high.adb.oraclecloud.com))(security=(ssl_server_dn_match=yes)))
