# -----------------------------------------------------------------------------
# Streamlit secrets template.
#
# LOCAL DEV:  copy this file to  .streamlit/secrets.toml  and fill it in.
# STREAMLIT CLOUD:  paste the same key=value pairs into
#                   App  ->  Settings  ->  Secrets  (do NOT commit the real file)
#
# .streamlit/secrets.toml is git-ignored — never commit real credentials.
# -----------------------------------------------------------------------------

DB_USER = "APP_USER"
DB_PASSWORD = "your-schema-password"

# Full one-way TLS connect string from tnsnames.ora (the _high alias's value).
# Paste it on ONE line. Example shape:
DB_DSN = "(description=(retry_count=20)(retry_delay=3)(address=(protocol=tcps)(port=1521)(host=adb.us-ashburn-1.oraclecloud.com))(connect_data=(service_name=abcd1234_mydb_high.adb.oraclecloud.com))(security=(ssl_server_dn_match=yes)))"
